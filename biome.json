{
	"$schema": "https://biomejs.dev/schemas/1.7.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignore": ["dist/**", ".astro/**", "**/.astro/**"]
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noExplicitAny": "warn"
			},
			"complexity": {
				"noForEach": "warn"
			}
		}
	}
}
