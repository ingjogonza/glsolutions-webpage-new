---
import Logo from "@/components/ui/Logo.astro";
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig, socialLinks } from "@/config/site.js";

const currentYear = new Date().getFullYear();

const footerLinks = {
  product: [
    { name: "Features", url: "/features" },
    { name: "Pricing", url: "/pricing" },
    { name: "Changelog", url: "/changelog" },
    { name: "Sign in", url: "/sign-in" },
    { name: "Sign up", url: "/sign-up" },
  ],
  resources: [
    { name: "Blog", url: "/blog" },
    { name: "Elements", url: "/elements" },
    { name: "404", url: "/404" },
    { name: "Docs", url: siteConfig.social.github + "#readme" },
    { name: "GitHub", url: siteConfig.social.github },
  ],
  company: [
    { name: "About", url: "/about" },
    { name: "Contact", url: "/contact" },
  ],
  legal: [
    { name: "License (MIT)", url: siteConfig.social.github + "/blob/main/LICENSE" },
  ],
};

const templateVersion = "v1.0.0";
---

<section class="text-gray-700 border-t mt-20 md:mt-48 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]">
  <div class="container mx-auto px-7 max-w-7xl py-12 md:py-16">
    <!-- Top: Logo + Description -->
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8 mb-12">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
          A polished SaaS template built with Astro and Tailwind CSS. Open-source, fast, and ready for production.
        </p>
      </div>

      <!-- Four columns -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 md:gap-12">
        <!-- Product -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">Product</h4>
          <ul class="space-y-3">
            {footerLinks.product.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">Resources</h4>
          <ul class="space-y-3">
            {footerLinks.resources.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">Company</h4>
          <ul class="space-y-3">
            {footerLinks.company.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h4 class="text-sm font-semibold text-neutral-800 dark:text-neutral-200 mb-4">Legal</h4>
          <ul class="space-y-3">
            {footerLinks.legal.map((link) => (
              <li>
                <a href={link.url} class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-primary dark:hover:text-primary-light transition-colors duration-200">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-dashed border-primary/10 dark:border-primary-dark/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-400 dark:text-neutral-500">
        © {currentYear}
        <a href={siteConfig.url || " "} target="_blank" class="hover:text-primary dark:hover:text-primary-light transition-colors">{siteConfig.author || " "}</a>.
        Released under the MIT License.
      </p>

      <div class="flex items-center gap-4">
        <span class="inline-flex items-center gap-2 text-xs text-neutral-400 dark:text-neutral-500">
          <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full border border-dashed border-primary/30 text-primary/80">
            <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
            {templateVersion}
          </span>
          <span>Built with Astro & Tailwind</span>
        </span>
        <span class="inline-flex justify-center space-x-4">
          {socialLinks.map((social) => (
            <a
              href={social.url}
              target="_blank"
              class="footer-social-icon-link text-neutral-400 dark:text-neutral-500 hover:text-primary dark:hover:text-primary-light transition-colors duration-200"
              title={social.name}
            >
              <span class="sr-only">{social.name}</span>
              <div class="footer-social-icon">
                <Fragment set:html={social.icon} />
              </div>
            </a>
          ))}
        </span>
      </div>
    </div>
  </div>
</section>

<!-- Back to top -->
<ToTop />

<style is:global>
  .footer-social-icon {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .footer-social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .footer-social-icon-link:hover .ic-twitter {
    color: #1DA1F2;
  }

  .footer-social-icon-link:hover .ic-github {
    color: #333;
  }

  .footer-social-icon-link:hover .ic-rss {
    color: #F26522;
  }
</style>
