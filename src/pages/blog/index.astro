---
import PageHeader from "@/components/elements/PageHeader.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import Layout from "@/layouts/Layout.astro";

const POSTS_PER_PAGE = 6;
const currentPage = 1;
---

<Layout title="Blog GL Solutions — Spec Driven Development, casos y metodología" description="Artículos sobre Spec Driven Development, casos reales de implementación y por qué documentar antes de programar reduce riesgo en startups B2B SaaS y Fintech.">
  <section class="relative z-20 container mx-auto my-12 px-7 lg:px-0">
    <PageHeader
      title="Blog"
      description="Artículos sobre Spec Driven Development, casos reales y metodología."
    />
  </section>
  <section class="relative z-20 mx-auto my-12 lg:px-0">
    <div class="mt-12">
      <BlogSection
        title=""
        listPage={true}
        pagination={{
          enable: true,
          currentPage: currentPage
        }}
        postsPerPage={POSTS_PER_PAGE}
      />
    </div>
  </section>
</Layout>
