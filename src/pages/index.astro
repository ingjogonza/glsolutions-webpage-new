---
import SectionHeader from "@/components/elements/SectionHeader.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { ArrowRight, Check, Cpu, Map as MapIcon, Users } from "@lucide/astro";

// Datos — Problema: 5 puntos de dolor.
const problemPoints = [
	"La IA genera código rápido, pero nadie sabe qué rompe qué.",
	"Si el dev que construyó el sistema se va, el conocimiento se va con él.",
	"Pagaste por desarrollo y no puedes revisarlo ni explicar lo que recibiste.",
	"Los releases se hacen más lentos aunque el equipo trabaje igual.",
	"Un inversor técnico pide ver la arquitectura y nadie puede explicarla.",
];

// Datos — Solución: comparación de dos columnas.
const comparison = {
	sinMapa: [
		"La IA genera código sin entender el negocio",
		"Nadie sabe qué rompe qué cuando algo cambia",
		"La deuda técnica crece en silencio hasta que explota",
		"Si el equipo se va, el conocimiento se va con ellos",
	],
	conSdd: [
		"El sistema está documentado antes de construirse",
		"La IA construye lo que el ingeniero definió",
		"Cada decisión técnica queda registrada y explicada",
		"Cualquier equipo puede tomar el proyecto desde el día uno",
	],
};

// Datos — Solución: 3 tarjetas.
const solutionCards = [
	{
		icon: MapIcon,
		title: "El mapa antes que el código",
		desc: "Documentamos cada decisión técnica antes de escribir la primera línea. La IA ejecuta el mapa, no lo inventa.",
	},
	{
		icon: Cpu,
		title: "La IA construye, el ingeniero decide",
		desc: "La IA acelera. La arquitectura, los trade-offs y el alcance los deciden los ingenieros.",
	},
	{
		icon: Users,
		title: "Cualquiera puede entenderlo",
		desc: "El sistema queda documentado de forma que cualquier desarrollador nuevo puede hacerse cargo desde el día uno.",
	},
];

// Datos — Proceso 5 fases: línea de tiempo.
const phases = [
	{
		num: "01",
		title: "Entendemos tu negocio",
		duration: "3–5 días",
		desc: "Documentamos cómo funciona tu dominio antes de tocar el teclado. Tú apruebas antes de seguir.",
	},
	{
		num: "02",
		title: "Diseñamos la estructura",
		duration: "4–6 días",
		desc: "Decidimos cómo está organizado el sistema y por qué, con las alternativas descartadas registradas. Tú apruebas antes de seguir.",
	},
	{
		num: "03",
		title: "Definimos qué hace cada parte",
		duration: "3–5 días",
		desc: "Documentamos exactamente qué debe pasar en cada funcionalidad, incluyendo casos difíciles y errores posibles. Tú firmas el alcance.",
	},
	{
		num: "04",
		title: "Construimos siguiendo el mapa",
		duration: "Iterativo",
		desc: "La IA construye lo definido en el paso anterior. Revisamos cada entrega contra los criterios aprobados.",
	},
	{
		num: "05",
		title: "Entregamos y te dejamos listo",
		duration: "3–4 días",
		desc: "Validamos que el sistema cumple lo acordado y entregamos toda la documentación para que cualquiera pueda continuar sin nosotros.",
	},
];

// Datos — Para quién: 3 personas.
const personas = [
	{
		title: "Founder técnico",
		points: [
			"usa IA para desarrollar pero el código no conecta con la lógica de negocio",
			"onboarding de nuevos devs toma semanas",
			"sin el founder nadie decide con criterio técnico",
			"lanzamientos cada vez más lentos sin explicación clara",
		],
	},
	{
		title: "Founder de negocio",
		points: [
			"pagó por desarrollo y no puede entenderlo ni explicarlo a un inversor",
			"plazos se extienden sin explicación",
			"si el equipo se va, el conocimiento se va con ellos",
			"no sabe si el sistema aguantará al crecer",
		],
	},
	{
		title: "Operaciones sin automatizar",
		points: [
			"equipo 100% en producto, sin tiempo para automatizar",
			"flujos en N8N/Make que nadie entiende y se rompen",
			"procesos manuales (onboarding, notificaciones, reportes)",
			"el trabajo manual escala junto con el volumen",
		],
	},
];

// Datos — Servicios teaser: 5 líneas.
const services = [
	{
		name: "Ejecución",
		desc: "Construimos tu sistema siguiendo SDD de punta a punta.",
	},
	{
		name: "Rescate",
		desc: "Recuperamos un proyecto que nadie entiende y lo documentamos.",
	},
	{
		name: "Consultoría",
		desc: "Acompañamos a tu equipo para adoptar Spec Driven Development.",
	},
	{
		name: "CTO Fraccionado",
		desc: "Definimos arquitectura y criterios técnicos por horas.",
	},
	{
		name: "Automatización",
		desc: "Reemplazamos procesos manuales por flujos documentados.",
	},
];
---

<Layout
  title={siteConfig.meta.title}
  description={siteConfig.meta.description}
  keywords={siteConfig.meta.keywords}
>

  {/* 1. HERO */}
  <section class="py-16 md:py-24 lg:py-28 site-container" data-aos="fade-up-xs" data-aos-once="true">
    <div class="max-w-3xl mx-auto text-center">
      <Badge variant="primary" size="lg">B2B SaaS · Fintech · Seed / Pre-seed</Badge>
      <h1 class="mt-6 text-4xl md:text-5xl lg:text-6xl font-brand text-neutral-800 dark:text-neutral-100 leading-tight tracking-normal">
        Spec Driven Development para startups B2B SaaS y Fintech en Chile y LatAm
      </h1>
      <p class="mt-6 text-base md:text-lg text-neutral-600 dark:text-neutral-300 leading-relaxed">
        Construimos sistemas para startups en cualquier parte del mundo. Antes de escribir una línea de código, documentamos cada decisión técnica. La IA acelera el trabajo — los ingenieros mantienen el control.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button url={`mailto:${siteConfig.mail}`} type="fill" className="text-lg px-8 py-3.5">
          Escríbenos a hola@glsolutions.tech <ArrowRight size={18} />
        </Button>
        <Button url="#evidencia" type="outline" className="text-lg px-8 py-3.5">
          Ver un ejemplo real →
        </Button>
      </div>
      <dl class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div>
          <dt class="text-3xl font-brand text-primary">15+</dt>
          <dd class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Años de experiencia aplicada</dd>
        </div>
        <div>
          <dt class="text-3xl font-brand text-primary">5</dt>
          <dd class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Fases con puerta de calidad</dd>
        </div>
        <div>
          <dt class="text-3xl font-brand text-primary">0</dt>
          <dd class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Decisiones técnicas sin documentar</dd>
        </div>
      </dl>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 2. PROBLEMA */}
  <section class="py-16 md:py-24 site-container">
    <SectionHeader
      title="¿Tu código crece, pero tu equipo lo entiende cada vez menos?"
      description="Estos problemas tienen un origen común: el sistema se construyó sin que nadie definiera primero cómo debía funcionar."
    />
    <ul class="mt-10 max-w-3xl mx-auto space-y-4">
      {problemPoints.map((point) => (
        <li class="flex gap-3 items-start text-neutral-700 dark:text-neutral-300 leading-relaxed">
          <span class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full bg-primary"></span>
          <span>{point}</span>
        </li>
      ))}
    </ul>
    <p class="mt-10 max-w-3xl mx-auto text-neutral-600 dark:text-neutral-300 leading-relaxed">
      Estos problemas tienen un origen común: el sistema se construyó sin que nadie definiera primero cómo debía funcionar. La IA genera código rápido, pero sin ese mapa previo genera sin contexto — y el equipo queda atrapado en lo que la máquina decidió. Existe una forma de construir software donde cada decisión queda registrada antes de escribir la primera línea de código.
    </p>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 3. SOLUCIÓN */}
  <section class="py-16 md:py-24 site-container">
    <SectionHeader
      title="Spec Driven Development — la spec define el sistema antes del código."
      description="En GL Solutions, antes de escribir una línea de código documentamos exactamente cómo debe funcionar el sistema: qué hace cada parte, por qué se tomó cada decisión y qué pasa en cada caso posible. Cuando eso está acordado y aprobado, recién entonces la IA construye — siguiendo ese mapa, no inventando el camino."
    />

    {/* Comparación de dos columnas */}
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      <div class="p-6 rounded-xl border border-neutral-200 dark:border-neutral-700 bg-bg-secondary dark:bg-bg-secondary-dark">
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-4">Sin mapa previo</h3>
        <ul class="space-y-3">
          {comparison.sinMapa.map((item) => (
            <li class="flex gap-3 items-start text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
              <span class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full bg-neutral-400"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="p-6 rounded-xl border border-primary/30 bg-primary/5 dark:bg-primary/10">
        <h3 class="text-lg font-semibold text-primary mb-4">Con SDD</h3>
        <ul class="space-y-3">
          {comparison.conSdd.map((item) => (
            <li class="flex gap-3 items-start text-sm text-neutral-700 dark:text-neutral-200 leading-relaxed">
              <Check size={16} class="mt-0.5 shrink-0 text-primary" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* 3 tarjetas */}
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {solutionCards.map((card, i) => (
        <div
          class="p-6 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700"
          data-aos="fade-up-sm"
          data-aos-delay={i * 100}
          data-aos-once="true"
        >
          <card.icon class="w-6 h-6 text-primary mb-3" />
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-100 mb-2">{card.title}</h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{card.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 4. EVIDENCIA */}
  <section id="evidencia" class="py-16 md:py-24 site-container scroll-mt-24">
    <SectionHeader
      title="Así se ve un sistema construido con SDD."
      description="Este es un ejemplo real del tipo de documento que GL Solutions produce antes de construir cualquier funcionalidad: el flujo completo de verificación de identidad de una plataforma Fintech."
    />
    <div class="mt-10 max-w-3xl mx-auto">
      <pre class="rounded-xl bg-neutral-900 text-neutral-100 dark:bg-neutral-950 p-6 overflow-x-auto text-sm leading-7 font-mono"><code>DADO QUE  usuario con estado KYC 'pendiente' ha subido cédula con ambas caras
CUANDO    el verificador externo devuelve score: 87 y los datos coinciden
ENTONCES  el perfil cambia a 'aprobado' automáticamente y queda habilitado</code></pre>
      <p class="mt-6 text-center">
        <a href="/blog/finpago-kyc-spec-driven-development" class="inline-flex items-center gap-1.5 text-primary font-medium hover:underline">
          Ver el caso completo <ArrowRight size={16} />
        </a>
      </p>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 5. PROCESO — 5 fases */}
  <section class="py-16 md:py-24 site-container">
    <SectionHeader
      title="Cómo trabajamos. Cinco pasos, cada uno requiere tu aprobación."
      description="Cada fase es una puerta de calidad: no avanzamos hasta que tú apruebas lo definido."
    />
    <div class="mt-12 relative max-w-3xl mx-auto">
      <div class="absolute left-4 md:left-5 top-1.5 bottom-1.5 w-px bg-neutral-200 dark:bg-neutral-700"></div>
      <ol class="space-y-10">
        {phases.map((phase, i) => (
          <li
            class="relative pl-12 md:pl-16"
            data-aos="fade-up-sm"
            data-aos-delay={i * 80}
            data-aos-once="true"
          >
            <div class="absolute left-0 top-0 w-9 h-9 md:w-11 md:h-11 rounded-full bg-primary text-neutral-50 flex items-center justify-center font-brand text-base shadow-sm">
              {phase.num}
            </div>
            <div class="mb-1 flex items-center gap-3 flex-wrap">
              <h3 class="text-base md:text-lg font-semibold text-neutral-800 dark:text-neutral-100">{phase.title}</h3>
              <Badge variant="primary" size="sm">{phase.duration}</Badge>
            </div>
            <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{phase.desc}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 6. PARA QUIÉN */}
  <section class="py-16 md:py-24 site-container">
    <SectionHeader
      title="¿Eres el cliente correcto para GL Solutions?"
      description="Trabajamos con founders y equipos que ya no toleran código que nadie entiende."
    />
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {personas.map((persona, i) => (
        <div
          class="p-6 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700"
          data-aos="fade-up-sm"
          data-aos-delay={i * 100}
          data-aos-once="true"
        >
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-100 mb-4">{persona.title}</h3>
          <ul class="space-y-3">
            {persona.points.map((point) => (
              <li class="flex gap-3 items-start text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                <span class="mt-2 shrink-0 w-1.5 h-1.5 rounded-full bg-primary"></span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 7. SERVICIOS TEASER */}
  <section class="py-16 md:py-24 site-container">
    <SectionHeader
      title="Cinco formas de trabajar con GL Solutions."
      description="Desde construir un sistema desde cero hasta rescatar uno que ya nadie entiende."
    />
    <ul class="mt-10 max-w-3xl mx-auto divide-y divide-neutral-200 dark:divide-neutral-700">
      {services.map((service) => (
        <li class="py-4 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-4">
          <span class="text-base font-semibold text-neutral-800 dark:text-neutral-100 sm:w-48 shrink-0">{service.name}</span>
          <span class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{service.desc}</span>
        </li>
      ))}
    </ul>
    <div class="mt-10 flex justify-center">
      <Button url="/servicios" type="outline" className="text-base px-6 py-3">
        Ver todos los servicios y precios <ArrowRight size={16} />
      </Button>
    </div>
  </section>

  {/* 8. CTA FINAL */}
  <section class="py-16 md:py-24 site-container">
    <div
      class="max-w-3xl mx-auto text-center rounded-xl px-6 py-16 md:py-20"
      style="background-color: #0F1F2E;"
    >
      <h2 class="text-3xl md:text-4xl font-brand text-neutral-50 mb-6">
        Software que cualquier ingeniero puede entender desde el día uno.
      </h2>
      <p class="mb-8">
        <a
          href={`mailto:${siteConfig.mail}`}
          class="inline-flex text-xl md:text-2xl font-medium text-primary-light underline-offset-4 hover:underline"
        >
          hola@glsolutions.tech
        </a>
      </p>
    </div>
  </section>

</Layout>