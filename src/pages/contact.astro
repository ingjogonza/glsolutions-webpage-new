---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";

// Datos — Proceso de contacto: 4 pasos.
const steps = [
	{
		num: "01",
		title: "Nos escribes",
		desc: "Nos escribes a hola@glsolutions.tech con una línea sobre tu proyecto.",
	},
	{
		num: "02",
		title: "Respondemos",
		desc: "Te respondemos en menos de 24 horas con dos opciones de horario.",
	},
	{
		num: "03",
		title: "Primera reunión",
		desc: "Primera reunión de 45 minutos — sin pitch, sin precio. Solo diagnóstico.",
	},
	{
		num: "04",
		title: "Propuesta",
		desc: "Si hay fit, recibes una propuesta con alcance y precio específico.",
	},
];
---

<Layout
  title={`Contacto — ${siteConfig.title}`}
  description={siteConfig.meta.description}
  keywords={siteConfig.meta.keywords}
>
  <main class="site-container py-12 md:py-20">

    {/* Encabezado */}
    <section class="max-w-2xl">
      <h1 class="font-brand text-4xl leading-tight tracking-normal text-neutral-800 dark:text-neutral-100 sm:text-5xl lg:text-6xl">
        Hablemos de tu proyecto
      </h1>
      <p class="mt-5 text-base leading-8 text-neutral-600 dark:text-neutral-300">
        Contanos qué estás construyendo y te decimos si podemos ayudarte. Sin formulario: escribinos directo.
      </p>
      <p class="mt-3 text-sm text-neutral-500 dark:text-neutral-400">
        No usamos formulario. Escribinos directo.
      </p>
    </section>

    {/* Proceso — 4 pasos */}
    <section class="mt-16 max-w-3xl">
      <div class="relative">
        <div class="absolute left-4 md:left-5 top-1.5 bottom-1.5 w-px bg-neutral-200 dark:bg-neutral-700"></div>
        <ol class="space-y-10">
          {steps.map((step, i) => (
            <li
              class="relative pl-12 md:pl-16"
              data-aos="fade-up-sm"
              data-aos-delay={i * 80}
              data-aos-once="true"
            >
              <div class="absolute left-0 top-0 w-9 h-9 md:w-11 md:h-11 rounded-full bg-primary text-neutral-50 flex items-center justify-center font-brand text-base shadow-sm">
                {step.num}
              </div>
              <h2 class="text-base md:text-lg font-semibold text-neutral-800 dark:text-neutral-100 mb-1">{step.title}</h2>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{step.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {/* CTA — único */}
    <section class="mt-16 md:mt-20 text-center">
      <div class="flex justify-center">
        <Button url={`mailto:${siteConfig.mail}`} type="fill" size="xl" className="max-w-none">
          {siteConfig.mail}
        </Button>
      </div>
    </section>

  </main>
</Layout>