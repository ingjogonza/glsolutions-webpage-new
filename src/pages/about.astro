---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { ArrowRight, Mail } from "@lucide/astro";

// Datos — Los fundadores.
const founders = [
	{
		name: "Jorge González",
		role: "Senior DBA y Data Architect",
		desc: "15+ años de experiencia en banca y automotriz. Ingeniero en Informática, con certificaciones en MongoDB y formación en ciencia de datos.",
		initials: "JG",
	},
	{
		name: "Carlos Lameda",
		role: "Ingeniero en Informática",
		desc: "Antes de GL Solutions fundó su propia empresa de tecnología en Venezuela, donde construyó las primeras experiencias de realidad aumentada del país. 15+ años de experiencia construyendo software.",
		initials: "CL",
	},
];
---

<Layout
  title="Sobre nosotros"
  description={siteConfig.meta.description}
  keywords={siteConfig.meta.keywords}
>

  {/* 1. ENCABEZADO */}
  <section class="site-container my-12 md:my-16">
    <h1 class="max-w-3xl font-brand text-4xl leading-tight tracking-normal text-neutral-800 dark:text-neutral-100 sm:text-5xl lg:text-6xl">
      Sobre GL Solutions
    </h1>
    <p class="mt-5 max-w-2xl text-base leading-8 text-neutral-600 dark:text-neutral-300">
      GL Solutions es una consultora de software y desarrollo para startups B2B SaaS y Fintech en Chile y Latinoamérica.
      Trabajamos con equipos en etapa semilla y pre-semilla aplicando una metodología que prioriza la trazabilidad
      por sobre la velocidad sin supervisión.
    </p>
  </section>

  {/* 2. LOS FUNDADORES */}
  <section class="site-container pb-16 md:pb-24">
    <h2 class="font-brand text-2xl tracking-normal text-neutral-800 dark:text-neutral-100 sm:text-3xl mb-8">
      Los fundadores
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-3xl">
      {founders.map((founder) => (
        <div class="p-5 rounded-xl bg-bg-secondary dark:bg-bg-secondary-dark border border-primary/10 dark:border-neutral-700">
          <div class="flex items-center gap-4 mb-3">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary text-neutral-50 font-brand text-base shadow-sm">
              {founder.initials}
            </span>
            <div class="min-w-0">
              <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-100">{founder.name}</h3>
              <p class="text-sm text-primary dark:text-primary-light">{founder.role}</p>
            </div>
          </div>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{founder.desc}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-neutral-500 dark:text-neutral-400 max-w-2xl">
      Somos el equipo de dos personas detrás de GL Solutions SpA (fundada en 2026).
    </p>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 3. MISIÓN */}
  <section class="py-16 md:py-24 site-container">
    <h2 class="font-brand text-2xl tracking-normal text-neutral-800 dark:text-neutral-100 sm:text-3xl mb-6">
      Nuestra misión
    </h2>
    <p class="max-w-2xl text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">
      Que cualquier startup pueda tener software que su equipo entiende, audita y puede transferir sin depender de quien lo construyó.
    </p>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 4. POSICIONAMIENTO */}
  <section class="py-16 md:py-24 site-container">
    <h2 class="font-brand text-2xl tracking-normal text-neutral-800 dark:text-neutral-100 sm:text-3xl mb-6">
      Cómo trabajamos
    </h2>
    <div class="max-w-2xl space-y-4 text-neutral-600 dark:text-neutral-300 leading-relaxed">
      <p>
        Ponemos rigor de ingeniería como contrapeso al código generado por IA sin supervisión arquitectónica.
        El enfoque común hoy es el “vibe coding”: la IA decide y los humanos ejecutan, sin mapa ni decisiones registradas.
      </p>
      <p>
        Ese modelo produce software que nadie puede auditar ni transferir. Nosotros invertimos el orden: primero documentamos
        el negocio y la arquitectura, después dejamos que la IA construya dentro de ese marco. Cada decisión técnica queda
        registrada, explicada y aprobada antes de avanzar.
      </p>
    </div>
    <p class="mt-6 text-sm text-neutral-500 dark:text-neutral-400">
      Sede en Santiago, Chile. Operamos en Chile y Latinoamérica.
    </p>
  </section>

  <div class="w-full border-b border-dashed border-neutral-200 dark:border-neutral-700 site-container"></div>

  {/* 5. CTA */}
  <section class="py-16 md:py-20 site-container text-center">
    <h2 class="font-brand text-2xl tracking-normal text-neutral-800 dark:text-neutral-100 sm:text-3xl mb-4">
      ¿Hablamos de tu proyecto?
    </h2>
    <p class="max-w-xl mx-auto text-sm text-neutral-500 dark:text-neutral-400 mb-8">
      Escríbenos y te respondemos en menos de 24 horas.
    </p>
    <div class="flex justify-center">
      <Button url={`mailto:${siteConfig.mail}`} type="fill" size="lg">
        <Mail size={18} /> {siteConfig.mail} <ArrowRight size={18} />
      </Button>
    </div>
  </section>

</Layout>