---
import Button from "@/components/ui/Button.astro";
import PageLayout from "@/layouts/PageLayout.astro";
import { ArrowLeft, Compass } from "@lucide/astro";
---

<PageLayout
  title="404 — Esta página no existe"
  description="El link que seguiste se rompió, o la página nunca existió."
>
  <section class="site-container py-14 md:py-24">
    <div class="grid min-h-[62vh] items-center gap-10 max-w-3xl">
      <div data-aos="fade-up-xs" data-aos-once="true">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-xs font-medium text-primary dark:border-primary-light/20 dark:bg-primary-light/10 dark:text-primary-light">
          <Compass size={14} />
          Error 404
        </p>

        <h1 class="max-w-2xl font-brand text-5xl leading-[1.04] tracking-normal text-neutral-800 dark:text-neutral-100 md:text-6xl">
          404 — Esta página no existe
        </h1>

        <p class="mt-5 max-w-xl text-base leading-8 text-neutral-600 dark:text-neutral-300">
          El link que seguiste se rompió, o la página nunca existió.           Vuelve al inicio y cuéntanos qué buscabas.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <Button url="/" type="fill" size="lg">
            <ArrowLeft size={16} /> Volver al inicio
          </Button>
        </div>
      </div>
    </div>
  </section>
</PageLayout>